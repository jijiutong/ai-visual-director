# ============================================================
# AI Visual Director — 统一系统配置
# 复制此文件为 .env 并填入实际 key。修改此文件全局生效。
# ============================================================
#
# 【.env 覆盖规则】
#   - .env（项目根目录，gitignore）存实际 API key，覆盖此模板
#   - 平台限制/阈值/拆分规则 → 读取此文件（.env 中无这些字段）
#   - 引擎读取顺序：先读 .env（API key），再读此文件（平台参数 + 阈值）
#   - 用户通过对话修改参数时，AI 应更新此文件（作为生效的默认值）
#
# 【平台参数命名规范】
#   所有引擎使用平键格式引用，不使用嵌套路径。
#   例如：用 SEEDANCE_MAX_DURATION，不用 platform.video.max_duration。
#   引擎通过当前目标平台拼接键名：{PLATFORM}_MAX_DURATION → 查此文件。
# ============================================================

# ===== 图片平台 — 密钥 / 模型 / 端点 =====
# GPT Image (OpenAI DALL-E 3)
OPENAI_API_KEY=***
GPT_IMAGE_MODEL=dall-e-3
GPT_IMAGE_ENDPOINT=https://api.openai.com/v1/images/generations

# Nano Banana (Google Gemini Image) — 需海外网络或代理
GEMINI_API_KEY=xxxxxxxxxxxx
NANO_BANANA_MODEL=gemini-2.5-flash-image
NANO_BANANA_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent

# Flux (via Replicate)
REPLICATE_API_TOKEN=***
FLUX_MODEL=black-forest-labs/flux-1.1-pro
FLUX_ENDPOINT=https://api.replicate.com/v1/predictions

# Stability AI (SD3)
STABILITY_API_KEY=***
STABILITY_MODEL=sd3
STABILITY_ENDPOINT=https://api.stability.ai/v2beta/stable-image/generate/sd3

# Ideogram — 需海外网络
IDEOGRAM_API_KEY=xxxxxxxxxxxx
IDEOGRAM_MODEL=V_2A
IDEOGRAM_ENDPOINT=https://api.ideogram.ai/generate

# 通义万相 (Alibaba Cloud DashScope) — 国内直连
DASHSCOPE_API_KEY=***
TONGYI_MODEL=qwen-image-2.0-pro
TONGYI_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation

# Recraft
RECRAFT_API_KEY=xxxxxxxxxxxx
RECRAFT_MODEL=recraftv3
RECRAFT_ENDPOINT=https://external.api.recraft.ai/v1/images/generations

# ComfyUI 本地
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_MODEL=flux-dev
COMFYUI_ENDPOINT={COMFYUI_BASE_URL}/prompt

# Midjourney — 无官方公开 API（替代：Replicate SDXL / ComfyUI 本地）

# ===== 视频平台 — 密钥 / 模型 / 端点 =====
# Seedance 2.0 (火山引擎 Ark) — 国内直连
ARK_API_KEY=xxxxxxxxxxxx
SEEDANCE_MODEL=doubao-seedance-2-0-260128
SEEDANCE_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/v1/contents/generations/tasks
SEEDANCE_POLL_ENDPOINT=https://ark.cn-beijing.volces.com/api/v3/v1/contents/generations/tasks/{task_id}

# Runway Gen-4.5 — 需海外网络
RUNWAY_API_KEY=key_xxxxxxxxxxxx
RUNWAY_MODEL=gen4.5
RUNWAY_ENDPOINT=https://api.dev.runwayml.com/v1/text_to_video

# 可灵 Kling (阿里云百炼) — 国内直连
KLING_API_KEY=xxxxxxxxxxxx
KLING_MODEL=kling-v3
KLING_ENDPOINT=https://dashscope.aliyuncs.com/api/v1/services/aigc/video-generation/video-synthesis

# Luma Dream Machine — 需海外网络（国内 DNS 解析正常但 TCP 被阻断）
LUMAAI_API_KEY=xxxxxxxxxxxx
LUMA_MODEL=ray-2
LUMA_ENDPOINT=https://api.lumalabs.ai/dream-machine/v1/generations

# Pika (via fal.ai)
FAL_API_KEY=xxxxxxxxxxxx
PIKA_MODEL=fal-ai/pika
PIKA_ENDPOINT=https://queue.fal.run/fal-ai/pika

# ===== 默认平台 =====
IMAGE_PLATFORM_DEFAULT=通义万相
VIDEO_PLATFORM_DEFAULT=Seedance

# ===== 视频平台限制 =====
# 引擎通过目标平台名拼接键名查找限制。格式：{PLATFORM}_MAX_DURATION / {PLATFORM}_MAX_REF_IMAGES / {PLATFORM}_MAX_PROMPT_CHARS / {PLATFORM}_SUPPORTS_CHINESE

# Seedance 2.0 — 中文故事视频默认首选
SEEDANCE_MAX_DURATION=15
SEEDANCE_MAX_REF_IMAGES=9
SEEDANCE_MAX_TOTAL_MATERIALS=12
SEEDANCE_MAX_PROMPT_CHARS=1500
SEEDANCE_SUPPORTS_CHINESE=true

# Runway Gen-4.5 — 国际化/API工作流
RUNWAY_MAX_DURATION=10
RUNWAY_MAX_REF_IMAGES=4
RUNWAY_MAX_PROMPT_CHARS=500
RUNWAY_SUPPORTS_CHINESE=false

# 可灵 Kling — 画质/动作强
KLING_MAX_DURATION=10
KLING_MAX_REF_IMAGES=3
KLING_MAX_PROMPT_CHARS=800
KLING_SUPPORTS_CHINESE=true

# Luma Dream Machine — 首尾帧插值
LUMA_MAX_DURATION=10
LUMA_MAX_REF_IMAGES=2
LUMA_MAX_PROMPT_CHARS=300
LUMA_SUPPORTS_CHINESE=false

# Pika — 短视频特效
PIKA_MAX_DURATION=5
PIKA_MAX_REF_IMAGES=2
PIKA_MAX_PROMPT_CHARS=300
PIKA_SUPPORTS_CHINESE=false

# ===== 图像平台语言支持 =====
# 引擎生成 prompt 时，语言必须匹配平台支持。
# 中文平台优先用中文，英文平台必须用英文。不可跨语言生成。
# 以下为各平台语言支持详情：
#
# 平台            中文      英文      备注
# GPT Image 2     ✅ 默认   ✅       原生中文，中文 prompt 更精准
# Midjourney v6+  ❌       ✅ 必须   只认英文，中文会报错
# SDXL / SD3      ❌       ✅ 推荐   英文效果最好
# DALL-E 3        ✅       ✅       原生中文
# Nano Banana     ✅       ✅       中文原生，14张参考图
# Flux            ⚠️ 部分  ✅ 推荐   英文为主
# Ideogram        ❌       ✅       英文
# 通义万相        ✅ 默认   ✅       中文原生
# Recraft         ❌       ✅       英文
# ComfyUI         ⚠️       ✅       取决于加载的 checkpoint
#
# Midjourney 无中文 = 必须翻译为英文。SDXL/SD3/Flux/Recraft = 推荐英文。

# ===== 自动拆分 =====
# 输入时长 > 平台最大单段时长 → 自动拆段
SPLIT_AUTO=true
# 拆分算法：段数 = ceil(输入时长 / {PLATFORM}_MAX_DURATION)
# 每段镜数 = ceil(总镜数 / 段数)
# 示例（60s / 15镜 → Seedance 15s上限）：
#   段数 = ceil(60/15) = 4段
#   每段 = 4镜（第4段3镜）
#   段1 0-15s | 段2 15-30s | 段3 30-45s | 段4 45-60s

# ===== 资产按段分配规则 =====
# 当内容被拆为多段时，资产按以下策略分配。非拆段场景（单段）则全部产出。
#
# 资产类型        分配策略
# 场景图          跨段复用（同一场景）或按段独立（不同场景）
# 角色卡          跨段复用（角色 DNA 不变）
# 全案分镜图       每段 1 张（7镜以内一张图清晰可读，>7镜拆多张）
# 高潮关键帧       每段 1 张（每段有自己的高潮镜）
# 首帧            段1首帧
# 尾帧            最后一段尾帧
# 段间接力         段N尾帧 = 段N+1首帧（自动锚定）
#
# ⚠ 禁止：60s 视频只出 1 张全案图塞 15 镜——看不清、视频工具也用不了。

# ===== 输入源路径 =====
# Obsidian Vault 根目录。`/source Obsidian 读取 [项目名]` 时从此目录扫描。
OBSIDIAN_VAULT_PATH=~/Documents/Obsidian
# 项目输出根目录（/create 产出写到这里）
OUTPUT_DIR=./output

# ===== 系统阈值 =====
SHORT_INPUT_THRESHOLD_CHARS=100
MID_INPUT_THRESHOLD_CHARS=2000
SCORE_PASS_THRESHOLD=85
REPAIR_MAX_ROUNDS=3
DEFAULT_ASPECT_RATIO=16:9
DEFAULT_LANGUAGE=zh
