# ============================================================
# AI Visual Director — 统一系统配置
# 复制此文件为 .env 并填入实际 key。修改此文件全局生效。
# ============================================================

# ===== AI 图片生成 API 密钥 =====
# Nano Banana (Google Gemini Image) - https://aistudio.google.com/apikey
GEMINI_API_KEY=xxxxxxxxxxxx
# GPT Image (OpenAI DALL-E 3) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxx
# Flux (via Replicate) - https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxx
# Ideogram - https://ideogram.ai/manage-api
IDEOGRAM_API_KEY=xxxxxxxxxxxx
# 通义万相 (Alibaba Cloud DashScope) - https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxx
# Recraft - https://www.recraft.ai/api
RECRAFT_API_KEY=xxxxxxxxxxxx
# ComfyUI 本地地址
COMFYUI_BASE_URL=http://127.0.0.1:8188
# Stable Diffusion XL/3 (Stability AI) - https://platform.stability.ai/
STABILITY_API_KEY=sk-xxxxxxxxxxxx
# Midjourney — 无官方公开 API（替代：Replicate SDXL / ComfyUI 本地）

# ===== AI 视频生成 API 密钥 =====
# Seedance 2.0 (火山引擎 Ark) - https://console.volcengine.com/ark
ARK_API_KEY=xxxxxxxxxxxx
# Runway Gen-4.5 - https://runwayml.com/settings/api
RUNWAY_API_KEY=key_xxxxxxxxxxxx
# 可灵 Kling (阿里云百炼) - https://dashscope.console.aliyun.com/
KLING_API_KEY=xxxxxxxxxxxx
# Luma Dream Machine - https://lumalabs.ai/api
LUMAAI_API_KEY=xxxxxxxxxxxx
# Pika (via fal.ai) - https://fal.ai/settings/api-keys
FAL_API_KEY=xxxxxxxxxxxx

# ===== 默认平台 =====
IMAGE_PLATFORM_DEFAULT=GPT Image 2
VIDEO_PLATFORM_DEFAULT=Seedance

# ===== 视频平台硬限制 =====
SEEDANCE_MAX_DURATION=15
SEEDANCE_MAX_REF_IMAGES=12
SEEDANCE_MAX_PROMPT_CHARS=1500
SEEDANCE_SUPPORTS_CHINESE=true
RUNWAY_MAX_DURATION=10
RUNWAY_MAX_REF_IMAGES=3
RUNWAY_MAX_PROMPT_CHARS=500
RUNWAY_SUPPORTS_CHINESE=false
KELING_MAX_DURATION=10
KELING_MAX_REF_IMAGES=3
KELING_MAX_PROMPT_CHARS=800
KELING_SUPPORTS_CHINESE=true
LUMA_MAX_DURATION=5
LUMA_MAX_REF_IMAGES=2
LUMA_MAX_PROMPT_CHARS=300
LUMA_SUPPORTS_CHINESE=false
SORA_MAX_DURATION=60
SORA_MAX_REF_IMAGES=1
SORA_MAX_PROMPT_CHARS=500
SORA_SUPPORTS_CHINESE=false
PIKA_MAX_DURATION=4
PIKA_MAX_REF_IMAGES=2
PIKA_MAX_PROMPT_CHARS=300
PIKA_SUPPORTS_CHINESE=false

# ===== 图像平台语言支持 =====
# GPT Image 2: zh,en | Midjourney: en | SDXL/SD3: en | DALL-E 3: zh,en
# Nano Banana: zh,en | Flux: en | Ideogram: en | 通义万相: zh | Recraft: en

# ===== 系统阈值 =====
SHORT_INPUT_THRESHOLD_CHARS=100
SCORE_PASS_THRESHOLD=85
REPAIR_MAX_ROUNDS=3
DEFAULT_ASPECT_RATIO=16:9
DEFAULT_LANGUAGE=zh
